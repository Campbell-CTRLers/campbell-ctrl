rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function adminConfigDoc() {
      return /databases/$(database)/documents/config/admins;
    }

    function isAuthorizedAdmin() {
      return request.auth != null &&
        request.auth.token.email is string &&
        exists(adminConfigDoc()) &&
        get(adminConfigDoc()).data.emails is list &&
        request.auth.token.email.lower() in get(adminConfigDoc()).data.emails;
    }

    function hasValidGlobalPayload() {
      return request.resource.data.keys().hasOnly(['gamesList', 'standings', 'rankings', 'meetings', 'siteContent']) &&
        request.resource.data.gamesList is list &&
        request.resource.data.standings is list &&
        request.resource.data.rankings is list &&
        request.resource.data.meetings is list &&
        request.resource.data.gamesList.size() <= 250 &&
        request.resource.data.standings.size() <= 250 &&
        request.resource.data.rankings.size() <= 250 &&
        request.resource.data.meetings.size() <= 250 &&
        (!('siteContent' in request.resource.data) || request.resource.data.siteContent is map);
    }

    // Admin email list — managed in Firebase Console, not committed to source
    match /config/admins {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Global data document (schedules and standings)
    match /global/data {
      // Allow ANYONE to read the data (so the website visitors can see schedules)
      allow read: if true;
      
      // Allow ONLY authenticated admins to write/overwrite the data
      // Emails are stored in Firestore
      allow write: if isAuthorizedAdmin() && hasValidGlobalPayload();
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
