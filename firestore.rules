rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin email list — managed in Firebase Console, not committed to source
    match /config/admins {
      allow read: if true;
      allow write: if false;
    }

    // Global data document (schedules and standings)
    match /global/data {
      // Allow ANYONE to read the data (so the website visitors can see schedules)
      allow read: if true;
      
      // Allow ONLY authenticated admins to write/overwrite the data
      // Emails are stored in Firestore
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/config/admins) &&
        request.auth.token.email in get(/databases/$(database)/documents/config/admins).data.emails;
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
